{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      "**/*.hbs",
      "**/*.pug",
      "**/*.ejs",
      "**/*.html",
      "public/**/*"
    ],
    "watchAssets": true
  }
}